{
  "appId": "com.zasly.kitchenpro",
  "copyright": "Copyright 2024 Zasly",
  "productName": "Zasly Kitchen Pro",
  "publish": [
    {
      "provider": "github",
      "owner": "Albert1711",
      "repo": "zasly-kitchen-pro"
    }
  ],
  "directories": {
    "output": "dist_electron"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "win": {
    "icon": "public/logo zasly inco.png",
    "target": [
      "nsis"
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "artifactName": "Zasly-Kitchen-Pro-Setup-${version}.${ext}",
    "uninstallDisplayName": "Zasly Kitchen Pro",
    "shortcutName": "Zasly Kitchen Pro",
    "deleteAppDataOnUninstall": true,
    "include": "build/uninstaller.nsh",
    "installerSidebar": "public/logo zasly inco.png",
    "uninstallerSidebar": "public/logo zasly inco.png",
    "installerHeader": "public/logo zasly inco.png"
  }
}
